# Load necessary packages
library(httr)
library(jsonlite)
# Define the function to get latitude and longitude from GeoNames API
get_lat_lon <- function(country_code, region) {
base_url <- "http://api.geonames.org/searchJSON"
username <- "MatteoB"  # replace with your GeoNames username
# Make the API request
response <- GET(base_url, query = list(
q = region,
country = country_code,
maxRows = 1,
username = username
))
# Check if the request was successful
if (status_code(response) == 200) {
data <- fromJSON(content(response, "text", encoding = "UTF-8"))
if (length(data$geonames) > 0) {
lat <- data$geonames[[1]]$lat
lng <- data$geonames[[1]]$lng
return(c(lat, lng))
}
}
return(c(NA, NA))
}
# Read the CSV file
#deane_nodes_csv <- "./input/list_of_nodes_utf8.csv"
#deane_nodes_df <- read.csv(deane_nodes_csv, sep = ";", stringsAsFactors = FALSE)
# Extract ISO3 and Geographical region
deane_nodes_df$ISO3 <- substr(deane_nodes_df$Node, 4, 6)
print(deane_nodes_df$ISO3)
deane_nodes_df$Geographical.region <- trimws(deane_nodes_df$Geographical.region)
print(deane_nodes_df$Geographical.region)
# Initialize columns for latitude and longitude
deane_nodes_df$Latitude <- NA
deane_nodes_df$Longitude <- NA
# Get latitude and longitude for each row
for (i in 1:nrow(deane_nodes_df)) {
country_code <- deane_nodes_df$ISO3[i]
region <- deane_nodes_df$Geographical.region[i]
lat_lon <- get_lat_lon(country_code, region)
deane_nodes_df$Latitude[i] <- lat_lon[1]
deane_nodes_df$Longitude[i] <- lat_lon[2]
}
# Print the updated dataframe
print(deane_nodes_df)
# Function to detect and remove BOM from a file
remove_bom <- function(file_path) {
con <- file(file_path, "rb")
bom <- readBin(con, what = raw(2))
if (identical(bom, raw(c(0xef, 0xbb, 0xbf)))) {
# BOM detected, skip first 3 bytes
readBin(con, "raw", n = 3)
}
lines <- readLines(con, encoding = "UTF-8")
close(con)
lines
}
